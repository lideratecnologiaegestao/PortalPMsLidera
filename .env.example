# ===== Banco (portal-postgres com PostGIS — papel de app SEM superusuário) =====
# IMPORTANTE: nunca use o superusuário 'postgres' — superusuário ignora RLS.
DATABASE_URL=postgresql://portal_app:CHANGE_ME@portal-postgres:5432/portal
# papel somente-leitura, usado pelo MCP postgres e relatórios
DATABASE_URL_READONLY=postgresql://portal_ro:CHANGE_ME@portal-postgres:5432/portal

# ===== Redis (REUSA o redis existente; DB e prefixo DEDICADOS ao portal) =====
# Evolution usa o DB 6 — o portal usa outro DB e um prefixo próprio para não colidir.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=1
REDIS_TLS=false
BULLMQ_PREFIX=portal

# ===== Object Storage (MinIO — S3-compatível; só a API acessa) =====
STORAGE_ENDPOINT=http://portal-minio:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=portal
STORAGE_ACCESS_KEY=CHANGE_ME
STORAGE_SECRET_KEY=CHANGE_ME
STORAGE_FORCE_PATH_STYLE=true

# ===== Antivírus (ClamAV daemon — varredura de uploads) =====
# vazio = sem varredura (dev). Em produção, aponte para o clamd (porta 3310).
CLAMAV_HOST=
CLAMAV_PORT=3310

# ===== API / Web =====
PORT=3001
API_URL=http://portal-api:3001
# token p/ proteger /api/metrics (Prometheus). Vazio = aberto (dev); em prod
# defina e/ou restrinja por IP no Nginx/Cloudflare (métricas têm tenant_id).
METRICS_TOKEN=
# CORS: origens permitidas (domínios das prefeituras), separadas por vírgula.
# Vazio em produção = só same-origin/sem-origin. Em dev qualquer origem é liberada.
ALLOWED_ORIGINS=

# ===== WhatsApp (adapter multi-provider — Z-API / Evolution / Meta Cloud stub) =====
# Seleção de provider (por tenant via admin/whatsapp/config; global = default de dev).
WHATSAPP_PROVIDER=zapi                       # zapi | evolution | meta
WHATSAPP_FALLBACK_PROVIDER=evolution         # provider secundário se o primário falhar

# Z-API — por tenant em produção (guardar no secret store). Aqui: default de dev.
ZAPI_BASE_URL=https://api.z-api.io/instances
ZAPI_INSTANCE_ID=__defina_por_tenant__
ZAPI_TOKEN=__defina_por_tenant__
ZAPI_CLIENT_TOKEN=__token_de_seguranca_da_conta__  # header Client-Token
ZAPI_WEBHOOK_SECRET=__string_aleatoria_no_path__   # gerado via admin/whatsapp/config

# Evolution API — mantida como fallback retrocompatível.
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=CHANGE_ME
EVOLUTION_INSTANCE=Lidera
# header de auth do Evolution é 'apikey' (minúsculo)

# URL pública da API (usada para montar URLs de webhook ao provisionar na Z-API).
# Deve ser HTTPS (a Z-API só aceita webhook HTTPS).
PUBLIC_API=https://api.sua-prefeitura.gov.br

# ===== gov.br Login Único (OIDC) =====
GOVBR_CLIENT_ID=
GOVBR_CLIENT_SECRET=
# deve apontar para o callback da API: https://<dominio-prefeitura>/api/auth/govbr/callback
GOVBR_REDIRECT_URI=
# homologação: https://sso.staging.acesso.gov.br | produção: https://sso.acesso.gov.br
GOVBR_PROVIDER_URL=https://sso.staging.acesso.gov.br
# (opcional) base da API de confiabilidades; default deriva de GOVBR_PROVIDER_URL
GOVBR_CONFIABILIDADES_URL=
GOVBR_SCOPES=openid email phone profile govbr_confiabilidades

# ===== Sessão do portal (JWT próprio do backend; NÃO é o id_token gov.br) =====
# segredo forte com >= 32 chars (use um gerador). Assina o cookie HttpOnly de sessão.
AUTH_JWT_SECRET=CHANGE_ME_min_32_chars_xxxxxxxxxxxxxxxxxx
AUTH_SESSION_TTL=8h
# pepper para o HMAC do CPF do cidadão (dedupe sem guardar CPF em claro — LGPD).
# gere com: openssl rand -hex 32. NUNCA versionar o valor real.
CPF_PEPPER=CHANGE_ME_hex_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Google Maps (app do cidadão) =====
GOOGLE_MAPS_API_KEY=

# ===== E-mail (SMTP) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ===== IA (triagem, RAG, chatbot, OCR) =====
ANTHROPIC_API_KEY=
# modelo do chat/triagem/tool use (vazio = default do código: claude-haiku-4-5)
IA_MODEL=
# modelo do OCR/visão (vazio = default do código: claude-sonnet-4-6).
# Mantido forte de propósito: o modelo leve troca números/datas em scans ruins.
IA_OCR_MODEL=
# RAG semântico — Camada 4 (embeddings + pgvector ia_chunks).
# Vazio = RAG usa full-text search em português (funciona sem infra extra).
# Provedor: voyage | openai (auto-detectado pela chave presente se omitido).
EMBEDDINGS_PROVIDER=
# Voyage AI (recomendado pela Anthropic; voyage-3 = 1024 dims nativo).
VOYAGE_API_KEY=
# OpenAI Embeddings (alternativa; usa dimensions:1024 via API).
OPENAI_API_KEY=
# Modelo a usar (padrão: voyage-3 p/ Voyage, text-embedding-3-small p/ OpenAI).
EMBEDDINGS_MODEL=
# Modelo de RERANK da Voyage AI (busca híbrida). Padrão: rerank-2.5.
VOYAGE_RERANK_MODEL=rerank-2.5

# ===== Diário Oficial (assinatura ICP-Brasil) =====
ICP_CERT_PATH=
ICP_CERT_PASSWORD=
# chave do STUB de assinatura (dev). Em produção, usar provedor ICP-Brasil real
# (PAdES/CAdES + carimbo de tempo de ACT) — ver signature.service.ts.
DIARIO_SIGNING_KEY=CHANGE_ME_dev_only
