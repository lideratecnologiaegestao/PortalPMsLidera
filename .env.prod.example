# =====================================================================
# TEMPLATE de PRODUÇÃO — copie para `.env.prod` e preencha com segredos
# do COFRE (NUNCA versione o `.env.prod` real; ele está no .gitignore).
# Usado por `docker-compose.prod.yml` (env_file) e como referência para
# Secret Manager (GCP) / Secrets Manager (AWS). Fonte completa: .env.example.
#
# Gerar segredos fortes:
#   AUTH_JWT_SECRET : openssl rand -base64 48
#   CPF_PEPPER      : openssl rand -hex 32
#   senhas/keys     : openssl rand -base64 32
# =====================================================================

NODE_ENV=production
PORT=3001

# ===== Banco (portal_app = papel de app SEM superusuário; preserva o RLS) =====
# Em produção, conecte via PgBouncer (transaction pooling): @pgbouncer:6432 + ?pgbouncer=true
DATABASE_URL=postgresql://portal_app:CHANGE_ME@portal-postgres:5432/portal
DATABASE_URL_READONLY=postgresql://portal_ro:CHANGE_ME@portal-postgres:5432/portal

# ===== Redis (BullMQ) — DB e prefixo dedicados ao portal =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=1
REDIS_TLS=false
BULLMQ_PREFIX=portal

# ===== Object Storage (MinIO / S3 — só a API acessa) =====
STORAGE_ENDPOINT=http://portal-minio:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=portal
STORAGE_ACCESS_KEY=CHANGE_ME
STORAGE_SECRET_KEY=CHANGE_ME
STORAGE_FORCE_PATH_STYLE=true

# ===== Antivírus (ClamAV) — varredura de uploads em produção =====
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ===== API / Web =====
API_URL=http://portal-api:3001
# Proteja /api/metrics (Prometheus) com token e/ou restrição de IP no proxy.
METRICS_TOKEN=CHANGE_ME
# Domínios das prefeituras (CORS), separados por vírgula. Vazio = só same-origin.
ALLOWED_ORIGINS=https://www.sua-prefeitura.gov.br

# ===== WhatsApp (adapter multi-provider) =====
WHATSAPP_PROVIDER=zapi
WHATSAPP_FALLBACK_PROVIDER=evolution
ZAPI_BASE_URL=https://api.z-api.io/instances
ZAPI_INSTANCE_ID=__defina_por_tenant__
ZAPI_TOKEN=__defina_por_tenant__
ZAPI_CLIENT_TOKEN=CHANGE_ME
ZAPI_WEBHOOK_SECRET=CHANGE_ME
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=CHANGE_ME
EVOLUTION_INSTANCE=Lidera
# URL pública HTTPS da API (webhooks). A Z-API só aceita webhook HTTPS.
PUBLIC_API=https://api.sua-prefeitura.gov.br

# ===== gov.br Login Único (OIDC) — produção: https://sso.acesso.gov.br =====
GOVBR_CLIENT_ID=CHANGE_ME
GOVBR_CLIENT_SECRET=CHANGE_ME
GOVBR_REDIRECT_URI=https://api.sua-prefeitura.gov.br/api/auth/govbr/callback
GOVBR_PROVIDER_URL=https://sso.acesso.gov.br
GOVBR_CONFIABILIDADES_URL=
GOVBR_SCOPES=openid email phone profile govbr_confiabilidades

# ===== Sessão do portal (JWT próprio do backend) =====
AUTH_JWT_SECRET=CHANGE_ME_min_32_chars
AUTH_SESSION_TTL=8h
# Pepper do HMAC do CPF (LGPD — dedupe sem guardar CPF em claro). openssl rand -hex 32
CPF_PEPPER=CHANGE_ME_hex_64_chars

# ===== Google Maps (app do cidadão) =====
GOOGLE_MAPS_API_KEY=

# ===== E-mail (SMTP) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ===== IA (triagem, RAG, chatbot, OCR) =====
ANTHROPIC_API_KEY=CHANGE_ME
# chat/triagem/tool use (vazio = default claude-haiku-4-5)
IA_MODEL=
# OCR/visão (vazio = default claude-sonnet-4-6; forte de propósito)
IA_OCR_MODEL=
# RAG semântico (Camada 4). Vazio = full-text em português (sem infra extra).
EMBEDDINGS_PROVIDER=
VOYAGE_API_KEY=
OPENAI_API_KEY=
EMBEDDINGS_MODEL=
VOYAGE_RERANK_MODEL=rerank-2.5

# ===== Diário Oficial (assinatura ICP-Brasil) =====
ICP_CERT_PATH=
ICP_CERT_PASSWORD=
DIARIO_SIGNING_KEY=CHANGE_ME
