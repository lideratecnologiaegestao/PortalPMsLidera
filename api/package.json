{
  "name": "portal-prefeitura-api",
  "version": "0.1.0",
  "description": "API multi-tenant do portal de prefeituras (NestJS + Prisma + RLS + BullMQ)",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate",
    "db:migrate": "for f in ../db/*.sql; do psql \"$DATABASE_URL\" -f \"$f\"; done",
    "aplic:import": "node dist/scripts/aplic-importar-lote.js",
    "test": "jest --config ./test/jest-unit.json",
    "test:e2e": "jest --runInBand --config ./test/jest-e2e.json"
  },
