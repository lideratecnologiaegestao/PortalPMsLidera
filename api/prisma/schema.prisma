// Prisma é a camada de QUERY. O RLS e as policies vivem no SQL (../db/*.sql),
// pois Prisma não expressa Row Level Security. Após rodar as migrations SQL,
// use `prisma db pull` para sincronizar — abaixo está o resultado esperado
// (resumido para os modelos usados neste scaffold).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext, postgis, unaccent, pg_trgm]
}

// @@map aponta para o NOME do tipo enum no Postgres (snake_case) — sem isso o
// Prisma casta para "public.UserRole" etc., que não existe (o DB usa user_role).
enum UserRole {
  super_admin
  admin_prefeitura
  gestor
  ouvidor
  assistente_ouvidoria
  ti
  servidor
  cidadao
  @@map("user_role")
}

enum ManifestacaoCanal {
  esic
  ouvidoria
  @@map("manifestacao_canal")
}

enum DiarioStatus {
  rascunho
  publicado
  revogado
  @@map("diario_status")
}

enum ManifestacaoTipo {
  acesso_informacao
  denuncia
  reclamacao
  sugestao
  elogio
  solicitacao
  @@map("manifestacao_tipo")
}

enum ManifestacaoStatus {
  registrada
  em_analise
  em_tratamento
  aguardando_cidadao
  prorrogada
  respondida
  indeferida
  parcialmente_atendida
  recurso_1a_instancia
  recurso_2a_instancia
  concluida
  arquivada
  @@map("manifestacao_status")
}

model Tenant {
  id                  String    @id @default(uuid()) @db.Uuid
  slug                String    @unique
  nome                String
  uf                  String    @db.Char(2)
  cnpj                String?   @unique
  municipioIbge       String?   @map("municipio_ibge")
  dominio             String?   @unique
  subdominio          String?   @unique
  plano               String    @default("padrao")
  ativo               Boolean   @default(true)
  iaTriagemHabilitada Boolean   @default(false) @map("ia_triagem_habilitada")
  iaChatHabilitada    Boolean   @default(false) @map("ia_chat_habilitada")
  cfCustomHostnameId  String?   @map("cf_custom_hostname_id")
  cfStatus            String?   @map("cf_status")
  cfValidacao         Json?     @map("cf_validacao")
  cfAtualizadoEm      DateTime? @map("cf_atualizado_em") @db.Timestamptz(6)
  dpoNome             String?   @map("dpo_nome")
  dpoEmail            String?   @map("dpo_email")
  atendimentoHumanoAtivo    Boolean @default(false) @map("atendimento_humano_ativo")
  iaChatWidgetAtivo         Boolean @default(false) @map("ia_chat_widget_ativo")
  atendimentoAvisoLgpd      String? @map("atendimento_aviso_lgpd")
  atendimentoMensagemForaExp String? @map("atendimento_mensagem_fora_exp")
  atendimentoSaudacao       String? @map("atendimento_saudacao")
  atendimentoInatividadeMin Int     @default(30) @map("atendimento_inatividade_min")
  atendimentoTimezone       String  @default("America/Cuiaba") @map("atendimento_timezone")
  evolutionInstancia        String? @map("evolution_instancia")
  aplicHabilitado     Boolean   @default(false) @map("aplic_habilitado")
  aplicUg             String?   @map("aplic_ug")
  criadoEm            DateTime  @default(now()) @map("criado_em")
  atualizadoEm        DateTime  @updatedAt @map("atualizado_em")
  elevationRequests   ElevationRequest[]
  @@map("tenants")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String?   @map("tenant_id") @db.Uuid
  secretariaId  String?   @map("secretaria_id") @db.Uuid
  nome          String
  email         String
  senhaHash     String?   @map("senha_hash")
  cpfHash       String?   @map("cpf_hash")
  role          UserRole  @default(cidadao)
  govbrSub      String?   @map("govbr_sub")
  govbrNivel    Int?      @map("govbr_nivel") @db.SmallInt
  ultimoLoginEm DateTime? @map("ultimo_login_em")
  senhaAlteradaEm DateTime? @map("senha_alterada_em")
  mfaSecret     String?   @map("mfa_secret")
  mfaHabilitado Boolean   @default(false) @map("mfa_habilitado")
  avatarStorageKey String? @map("avatar_storage_key")
  avatarMime    String?   @map("avatar_mime")
  telefone      String?
  emailVerificado    Boolean @default(false) @map("email_verificado")
  telefoneVerificado Boolean @default(false) @map("telefone_verificado")
  ativo         Boolean   @default(true)
  /// Conta virtual de bot (Assistente do Portal). Nunca autentica — migration 073.
  isBot         Boolean   @default(false) @map("is_bot")
  // Relações inversas — migration 046
  grupos        UsuarioGrupo[]
  sessions      UserSession[]
  sessionsRevogadas UserSession[] @relation("SessionRevogadoPor")
  // Relações inversas — migration 048 (LGPD)
  solicitacoesTitular  SolicitacaoTitular[] @relation("SolicitacaoTitular")
  solicitacoesTratadas SolicitacaoTitular[] @relation("SolicitacaoTratadaPor")
  incidentesResponsavel IncidenteSeguranca[] @relation("IncidenteResponsavel")
  // Relação inversa — migration 049 (formulários)
  enviosFormulario     FormularioEnvio[]
  // Relações inversas — migration 050 (atendimento omnichannel)
  atendConversasCidadao AtendimentoConversa[] @relation("AtendConversaCidadao")
  atendConversasAgente  AtendimentoConversa[] @relation("AtendConversaAgente")
  atendMensagens        AtendimentoMensagem[]
  atendEventos          AtendimentoEvento[]
  // Relações inversas — migration 069 (solicitações de elevação de papel)
  elevacoesSolicitadas  ElevationRequest[]    @relation("ElevacaoSolicitante")
  elevacoesAprovadas    ElevationRequest[]    @relation("ElevacaoAprovador")
  // Relações inversas — migration 074 (comentários em notícias)
  comentariosAutor      NoticiaComentario[]   @relation("ComentariosAutor")
  comentariosModerador  NoticiaComentario[]   @relation("ComentariosModerador")
  // Relações inversas — migration 076 (builds do app do cidadão)
  appBuilds             TenantAppBuild[]
  // Relações inversas — migration 084 (campanhas)
  campanhasCriadas      Campaign[]
  @@unique([tenantId, email])
  @@unique([tenantId, govbrSub])
  @@map("users")
}

/// Solicitação de elevação de papel (ADR-0005 Fase 2) — migration 069.
model ElevationRequest {
  id                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String     @map("tenant_id") @db.Uuid
  userId               String     @map("user_id") @db.Uuid
  papelSolicitado      UserRole   @map("papel_solicitado")
  cargoDeclarado       String?    @map("cargo_declarado")
  lotacaoSecretariaId  String?    @map("lotacao_secretaria_id") @db.Uuid
  justificativa        String?
  /// Status FSM: pendente → aprovada | recusada | expirada
  status               String     @default("pendente")
  aprovadoPor          String?    @map("aprovado_por") @db.Uuid
  aprovadoEm           DateTime?  @map("aprovado_em") @db.Timestamptz(6)
  motivoRecusa         String?    @map("motivo_recusa")
  criadoEm             DateTime   @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm         DateTime   @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  tenant               Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  solicitante          User       @relation("ElevacaoSolicitante", fields: [userId], references: [id], onDelete: Cascade)
  aprovadorUser        User?      @relation("ElevacaoAprovador",   fields: [aprovadoPor], references: [id], onDelete: SetNull)
  lotacaoSecretaria    Secretaria? @relation(fields: [lotacaoSecretariaId], references: [id], onDelete: SetNull)
  @@index([tenantId, status])
  @@index([userId])
  @@map("elevation_requests")
}

/// Requisição de direitos do titular (LGPD art. 18) — migration 048.
model SolicitacaoTitular {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  titularId           String    @map("titular_id") @db.Uuid
  tipo                String
  descricao           String?
  status              String    @default("aberta")
  prazoEm             DateTime  @map("prazo_em") @db.Timestamptz(6)
  atrasada            Boolean   @default(false)
  resposta            String?
  indeferimentoMotivo String?   @map("indeferimento_motivo")
  anexoStorageKey     String?   @map("anexo_storage_key")
  tratadoPor          String?   @map("tratado_por") @db.Uuid
  tratadoEm           DateTime? @map("tratado_em") @db.Timestamptz(6)
  criadoEm            DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm        DateTime  @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  titular             User      @relation("SolicitacaoTitular", fields: [titularId], references: [id], onDelete: Restrict)
  tratadoPorUser      User?     @relation("SolicitacaoTratadaPor", fields: [tratadoPor], references: [id], onDelete: SetNull)
  @@index([tenantId, status])
  @@index([titularId])
  @@map("solicitacoes_titular")
}

/// Registro/comunicação de incidente de segurança (LGPD art. 48) — migration 048.
model IncidenteSeguranca {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                  String    @map("tenant_id") @db.Uuid
  titulo                    String
  descricao                 String
  categoria                 String
  natureza                  String?
  dadosAfetados             String[]  @map("dados_afetados")
  titularesAfetadosEstimados Int?     @map("titulares_afetados_estimados")
  severidade                String
  riscoDescricao            String?   @map("risco_descricao")
  riscoNivel                String?   @map("risco_nivel")
  ocorridoEm                DateTime? @map("ocorrido_em") @db.Timestamptz(6)
  detectadoEm               DateTime  @default(now()) @map("detectado_em") @db.Timestamptz(6)
  prazoComunicacaoEm        DateTime  @map("prazo_comunicacao_em") @db.Timestamptz(6)
  comunicacaoAtrasada       Boolean   @default(false) @map("comunicacao_atrasada")
  status                    String    @default("registrado")
  medidasContencao          String?   @map("medidas_contencao")
  medidasMitigacao          String?   @map("medidas_mitigacao")
  comunicadoAnpd            Boolean   @default(false) @map("comunicado_anpd")
  comunicadoAnpdEm          DateTime? @map("comunicado_anpd_em") @db.Timestamptz(6)
  comunicadoAnpdProtocolo   String?   @map("comunicado_anpd_protocolo")
  comunicadoTitulares       Boolean   @default(false) @map("comunicado_titulares")
  comunicadoTitularesEm     DateTime? @map("comunicado_titulares_em") @db.Timestamptz(6)
  comunicadoTitularesMeio   String?   @map("comunicado_titulares_meio")
  responsavelId             String?   @map("responsavel_id") @db.Uuid
  criadoEm                  DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm              DateTime  @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  responsavel               User?     @relation("IncidenteResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  @@index([tenantId, status])
  @@index([tenantId, detectadoEm])
  @@map("incidentes_seguranca")
}

/// Documentação LGPD gerada por entidade (template global + dados do tenant) — migration 062.
model LgpdDocumento {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @unique @map("tenant_id") @db.Uuid
  dados        Json      @default("{}")
  html         String?
  versao       Int       @default(1)
  publicado    Boolean   @default(false)
  publicadoEm  DateTime? @map("publicado_em") @db.Timestamptz(6)
  geradoEm     DateTime? @map("gerado_em") @db.Timestamptz(6)
  geradoPor    String?   @map("gerado_por") @db.Uuid
  criadoEm     DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm DateTime  @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  @@map("lgpd_documentos")
}

/// Formulário eletrônico (builder drag-drop) — migration 049.
model Formulario {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String      @map("tenant_id") @db.Uuid
  slug                String
  titulo              String
  descricao           String?
  schema              Json        @default("[]")
  status              String      @default("rascunho")
  mensagemConfirmacao String?     @map("mensagem_confirmacao")
  redirecionarUrl     String?     @map("redirecionar_url")
  loginObrigatorio    Boolean     @default(false) @map("login_obrigatorio")
  multiplosEnvios     Boolean     @default(true) @map("multiplos_envios")
  captchaHabilitado   Boolean     @default(true) @map("captcha_habilitado")
  notificarEmails     String[]    @map("notificar_emails")
  notificarCc         String[]    @map("notificar_cc")
  notificarBcc        String[]    @map("notificar_bcc")
  totalEnvios         Int         @default(0) @map("total_envios")
  /// Secretaria responsável pelo formulário — migration 071 (ADR-0005 Fase 4).
  secretariaId        String?     @map("secretaria_id") @db.Uuid
  criadoEm            DateTime    @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm        DateTime    @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  envios              FormularioEnvio[]
  secretaria          Secretaria? @relation(fields: [secretariaId], references: [id], onDelete: SetNull)
  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, secretariaId])
  @@map("formularios")
}

/// Resposta captada de um formulário (dado pessoal — LGPD) — migration 049.
model FormularioEnvio {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  formularioId String     @map("formulario_id") @db.Uuid
  dados        Json       @default("{}")
  anexos       Json       @default("[]")
  cidadaoId    String?    @map("cidadao_id") @db.Uuid
  ip           String?    @db.Inet
  userAgent    String?    @map("user_agent")
  lido         Boolean    @default(false)
  criadoEm     DateTime   @default(now()) @map("criado_em") @db.Timestamptz(6)
  formulario   Formulario @relation(fields: [formularioId], references: [id], onDelete: Cascade)
  cidadao      User?      @relation(fields: [cidadaoId], references: [id], onDelete: SetNull)
  @@index([tenantId, formularioId, criadoEm])
  @@map("formulario_envios")
}

/// Base de conhecimento curada do assistente de IA, por tenant — migration 053.
model IaConhecimento {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  pergunta     String
  resposta     String
  tags         String[]
  fixado       Boolean  @default(false)
  ativo        Boolean  @default(true)
  criadoPor    String?  @map("criado_por") @db.Uuid
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  // busca tsvector (GENERATED) é gerenciada pelo banco — usar raw query p/ FTS
  @@index([tenantId, ativo])
  @@map("ia_conhecimento")
}

/// Configuração de WhatsApp por tenant (adapter Z-API/Evolution/Meta) — migration 052.
model TenantWhatsappConfig {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String   @unique @map("tenant_id") @db.Uuid
  provider               String   @default("evolution")
  fallbackProvider       String?  @map("fallback_provider")
  zapiInstanceId         String?  @map("zapi_instance_id")
  zapiTokenCifrado       String?  @map("zapi_token_cifrado")
  zapiClientTokenCifrado String?  @map("zapi_client_token_cifrado")
  zapiWebhookSecret      String?  @map("zapi_webhook_secret")
  evolutionApiUrl        String?  @map("evolution_api_url")
  evolutionInstance      String?  @map("evolution_instance")
  evolutionApiKeyCifrado String?  @map("evolution_api_key_cifrado")
  metaPhoneNumberId      String?  @map("meta_phone_number_id")
  metaWabaId             String?  @map("meta_waba_id")
  metaTokenCifrado       String?  @map("meta_token_cifrado")
  metaAppSecretCifrado   String?  @map("meta_app_secret_cifrado")
  metaVerifyToken        String?  @map("meta_verify_token")
  metaWebhookSecret      String?  @map("meta_webhook_secret")
  ativo                  Boolean  @default(true)
  atualizadoEm           DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  criadoEm               DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  @@map("tenant_whatsapp_config")
}

/// Canal WhatsApp / Instagram Multi-número Meta por tenant — migration 081/082.
/// Cada linha representa um número Meta ou conta IG dedicado.
/// Credenciais cifradas em repouso via AES-256-GCM (secret-box.util).
/// webhook_secret é UNIQUE global — resolve tenant no webhook /webhooks/meta-canal/:secret.
model TenantWhatsappCanal {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  label                  String
  provider               String    @default("meta")
  /// 'whatsapp' | 'instagram' | 'messenger' | 'telegram' — migration 082/083.
  tipo                   String    @default("whatsapp") @map("tipo")
  /// Obrigatório para WhatsApp/Instagram/Messenger; nulo para Telegram (que usa apenas bot token).
  metaPhoneNumberId      String?   @map("meta_phone_number_id")
  metaWabaId             String?   @map("meta_waba_id")
  metaTokenCifrado       String?   @map("meta_token_cifrado")
  metaAppSecretCifrado   String?   @map("meta_app_secret_cifrado")
  metaVerifyToken        String?   @map("meta_verify_token")
  webhookSecret          String    @unique @map("webhook_secret")
  secretariaId           String?   @map("secretaria_id") @db.Uuid
  ativo                  Boolean   @default(true)
  ordem                  Int       @default(0)
  criadoEm               DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm           DateTime  @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  conversas              AtendimentoConversa[]
  templateEnvios         WhatsappTemplateEnvio[]
  secretaria             Secretaria? @relation(fields: [secretariaId], references: [id], onDelete: SetNull)
  @@unique([tenantId, label])
  @@index([tenantId])
  @@map("tenant_whatsapp_canais")
}

/// Cota de templates HSM por tenant — migration 082.
/// PK = tenant_id (singleton por tenant). RLS aplica.
model TenantWhatsappCota {
  tenantId         String   @id @map("tenant_id") @db.Uuid
  creditosTotal    Int      @default(0) @map("creditos_total")
  alertaPercentual Int      @default(80) @map("alerta_percentual")
  cicloDia         Int      @default(1) @map("ciclo_dia")
  atualizadoEm     DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  @@map("tenant_whatsapp_cota")
}

/// Log de envios de template HSM — migration 082.
/// Alimentado best-effort por WhatsappService após cada envio. RLS aplica.
model WhatsappTemplateEnvio {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  canalId      String?  @map("canal_id") @db.Uuid
  templateNome String   @map("template_nome")
  toMascarado  String   @map("to_mascarado")
  status       String   @default("enviado")
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  canal        TenantWhatsappCanal? @relation(fields: [canalId], references: [id], onDelete: SetNull)
  @@index([tenantId, criadoEm])
  @@index([tenantId, canalId])
  @@map("whatsapp_template_envios")
}

/// Configuração de IA por tenant — override opcional sobre o global — migration 056.
model TenantIaConfig {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String   @unique @map("tenant_id") @db.Uuid
  iaMaxChunks            Int?     @map("ia_max_chunks")
  embeddingsProvider     String?  @map("embeddings_provider")
  voyageApiKeyCifrado    String?  @map("voyage_api_key_cifrado")
  anthropicApiKeyCifrado String?  @map("anthropic_api_key_cifrado")
  openaiApiKeyCifrado    String?  @map("openai_api_key_cifrado")
  ativo                  Boolean  @default(true)
  atualizadoEm           DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  criadoEm               DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  @@map("tenant_ia_config")
}

/// Importação da carga contábil APLIC (TCE-MT), módulo CT — migration 057.
model AplicCarga {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  modulo         String
  ug             String?
  exercicio      Int
  competencia    String?
  arquivoNome    String?  @map("arquivo_nome")
