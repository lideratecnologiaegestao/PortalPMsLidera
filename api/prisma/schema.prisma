}

model AplicDotacao {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  cargaId     String?  @map("carga_id") @db.Uuid
  exercicio   Int
  competencia String?
  orgCodigo   String?  @map("org_codigo")
  unorCodigo  String?  @map("unor_codigo")
  dados       Json
  criadoEm    DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  @@map("aplic_dotacao")
