  parentId  String?   @map("parent_id") @db.Uuid
  local     MenuLocal @default(cabecalho)
  label     String
  tipo      MenuTipo  @default(interno)
  href      String?
  icone     String?
  ordem     Int       @default(0)
  ativo     Boolean   @default(true)
  refTipo   String?   @map("ref_tipo")
  refId     String?   @map("ref_id") @db.Uuid
  criadoEm  DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  parent    MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("MenuHierarchy")
  @@index([tenantId, local, parentId, ordem])
  @@map("menu_items")
}

model Servico {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  titulo            String
  slug              String
  descricao         String?
  categoria         String?
  orgaoResponsavel  String?  @map("orgao_responsavel")
  publicoAlvo       String?  @map("publico_alvo")
  requisitos        String?
  etapas            Json     @default("[]")
  canaisAtendimento String?  @map("canais_atendimento")
  prazoAtendimento  String?  @map("prazo_atendimento")
  custo             String?
  urlExterna        String?  @map("url_externa")
  publicado         Boolean  @default(false)
  destaque          Boolean  @default(false)
  avaliacaoSoma     Int      @default(0) @map("avaliacao_soma")
  avaliacaoQtd      Int      @default(0) @map("avaliacao_qtd")
  ordem             Int      @default(0)
  criadoEm          DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm      DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  avaliacoes        ServicoAvaliacao[]
  @@unique([tenantId, slug])
  @@map("servicos")
}

model ServicoAvaliacao {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  servicoId   String   @map("servico_id") @db.Uuid
  nota        Int      @db.SmallInt
  comentario  String?
  votanteHash String   @map("votante_hash")
  criadoEm    DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  servico     Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  @@unique([servicoId, votanteHash])
  @@index([tenantId, servicoId])
  @@map("servico_avaliacoes")
}

// ---- Grupos de acesso e sessões (migration 046_grupos_sessoes.sql) ----

/// Grupos de permissão configuráveis pelo município. Cada grupo agrega chaves
/// de permissão e pode ser atribuído a múltiplos usuários do tenant.
model GrupoAcesso {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  nome         String
  descricao    String?
  /// Array de chaves de permissão concedidas (ex.: "noticias.gerenciar").
  /// O catálogo canônico é definido no código da API.
  permissoes   String[]       @map("permissoes")
  ativo        Boolean        @default(true)
  criadoEm     DateTime       @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm DateTime       @default(now()) @map("atualizado_em") @db.Timestamptz(6)
  membros      UsuarioGrupo[]
  cadastrosRestritos DocCadastroGrupo[]
  @@unique([tenantId, nome])
  @@index([tenantId, ativo])
  @@map("grupos_acesso")
}

/// Associação N:N usuário ↔ grupo de acesso (escopo de tenant).
model UsuarioGrupo {
  tenantId  String      @map("tenant_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  grupoId   String      @map("grupo_id") @db.Uuid
  criadoEm  DateTime    @default(now()) @map("criado_em") @db.Timestamptz(6)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  grupo     GrupoAcesso @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  @@id([userId, grupoId])
  @@index([grupoId])
  @@index([tenantId])
  @@map("usuario_grupos")
}

/// Registro durável de sessões JWT. Permite listar sessões ativas, exibir
/// usuários online e revogar tokens server-side. O id corresponde ao jti do JWT.
model UserSession {
  id                 String    @id @db.Uuid
  /// NULL para sessões de super_admin (escopo de plataforma).
  tenantId           String?   @map("tenant_id") @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  ip                 String?   @db.Inet
  userAgent          String?   @map("user_agent")
  criadoEm           DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  ultimaAtividadeEm  DateTime  @default(now()) @map("ultima_atividade_em") @db.Timestamptz(6)
  expiraEm           DateTime  @map("expira_em") @db.Timestamptz(6)
  /// NULL = sessão ativa. Preenchido na revogação manual ou automática.
  revogadoEm         DateTime? @map("revogado_em") @db.Timestamptz(6)
  /// UUID de quem revogou (admin ou o próprio usuário). NULL para expiração automática.
  revogadoPor        String?   @map("revogado_por") @db.Uuid
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  revogadoPorUser    User?     @relation("SessionRevogadoPor", fields: [revogadoPor], references: [id], onDelete: SetNull)
  @@index([tenantId, revogadoEm])
  @@index([userId])
  @@index([expiraEm])
  @@map("user_sessions")
}

// ---- Buscador unificado — índice desnormalizado (migration 060_busca_unificada.sql) ----

/// Índice full-text cross-módulo. Cada linha representa um item pesquisável
/// (notícia, documento, serviço, etc.). Atualizado pelo BuscaSyncWorker;
/// nunca escreva diretamente aqui — use BuscaSyncService.indexar().
///
/// `corpo_tsv` é tsvector (tipo não suportado nativamente pelo Prisma);
/// todas as operações de busca e UPSERT usam $queryRaw/$executeRaw.
/// Este model existe apenas para que o Prisma conheça a tabela no schema.
model SearchIndex {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  tipo        String
  refId       String    @map("ref_id")
  titulo      String
  subtitulo   String?
  url         String
  /// tsvector pré-computado pelo worker — tipo não suportado pelo Prisma Client;
  /// consulte via $queryRaw.
  corpoTsv    Unsupported("tsvector") @map("corpo_tsv")
  snippetSrc  String?   @map("snippet_src")
  peso        Float     @default(1.0) @db.Real
  publicadoEm DateTime? @map("publicado_em") @db.Timestamptz(6)
  atualizadoEm DateTime @default(now()) @map("atualizado_em") @db.Timestamptz(6)

  @@unique([tenantId, tipo, refId])
  @@index([tenantId, tipo, publicadoEm(sort: Desc)])
  @@map("search_index")
}

/// Redirecionamentos 301/302 administráveis por tenant (migration 055).
/// Permite migrar URLs legadas (Joomla, WordPress...) para novos slugs sem perder SEO.
model Redirect {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  origem       String
  destino      String
  statusCode   Int      @default(301) @map("status_code") @db.SmallInt
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  @@unique([tenantId, origem])
  @@index([tenantId, origem])
  @@map("redirects")
}

/// Configuração white-label do App do Cidadão por tenant (ADR-0006 Fase 1) — migration 076.
/// Uma linha por prefeitura (UNIQUE tenant_id). Campos build-time alimentam o pipeline EAS;
/// campos runtime são lidos pelo app na inicialização. Sem PII; base legal: LGPD art. 7º III.
model TenantAppConfig {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String   @unique @map("tenant_id") @db.Uuid

  // Identidade do build (build-time)
  appName             String?  @map("app_name")
  appShortName        String?  @map("app_short_name")
  bundleId            String?  @map("bundle_id")
  scheme              String?
  apiUrl              String?  @map("api_url")
  easProjectId        String?  @map("eas_project_id")
  easOwner            String?  @map("eas_owner")
  appVersion          String   @default("1.0.0") @map("app_version")

  // Assets de build (storage keys — build-time)
  iconStorageKey      String?  @map("icon_storage_key")
  splashStorageKey    String?  @map("splash_storage_key")
  splashBgColor       String   @default("#1351b4") @map("splash_bg_color")

  // Tema (runtime)
  primaryColor        String   @default("#1351b4") @map("primary_color")
  secondaryColor      String   @default("#071d41") @map("secondary_color")

  // Módulos (runtime)
  moduloDenuncia      Boolean  @default(true)  @map("modulo_denuncia")
  moduloMapa          Boolean  @default(true)  @map("modulo_mapa")
  moduloOuvidoria     Boolean  @default(true)  @map("modulo_ouvidoria")
  moduloEsic          Boolean  @default(true)  @map("modulo_esic")
  moduloChat          Boolean  @default(false) @map("modulo_chat")
  moduloServicos      Boolean  @default(true)  @map("modulo_servicos")
  moduloNoticias      Boolean  @default(true)  @map("modulo_noticias")
  moduloCarteira      Boolean  @default(false) @map("modulo_carteira")
  moduloGaleria       Boolean  @default(true)  @map("modulo_galeria")
  moduloDocumentos    Boolean  @default(true)  @map("modulo_documentos")

  // Conteúdo institucional (runtime, JSONB)
  onboardingSlides    Json     @default("[]") @map("onboarding_slides")
  acessoRapido        Json     @default("[]") @map("acesso_rapido")
  categoriasChamados  Json     @default("[]") @map("categorias_chamados")

  // Push / comportamento (runtime)
  pushHabilitado      Boolean  @default(true)  @map("push_habilitado")
  biometriaHabilitada Boolean  @default(false) @map("biometria_habilitada")
  onboardingAtivo     Boolean  @default(true)  @map("onboarding_ativo")

  criadoEm            DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm        DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  builds              TenantAppBuild[]

  @@index([tenantId])
  @@map("tenant_app_config")
}

/// Histórico de builds EAS por tenant (ADR-0006) — migration 076.
/// Criada na Fase 1; painel de acionamento entregue na Fase 2.
model TenantAppBuild {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  perfil        String                                      // preview | production
  plataforma    String    @default("android")               // android | ios | all
  status        String    @default("enfileirado")           // FSM: enfileirado→preparando→em_build→concluido|falhou
  easBuildId    String?   @map("eas_build_id")
  easBuildUrl   String?   @map("eas_build_url")
  logUrl        String?   @map("log_url")
  erroResumo    String?   @map("erro_resumo")
  solicitadoPor String?   @map("solicitado_por") @db.Uuid

  criadoEm     DateTime   @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm DateTime   @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  config        TenantAppConfig? @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  solicitante   User?            @relation(fields: [solicitadoPor], references: [id], onDelete: SetNull)

  @@index([tenantId, criadoEm(sort: Desc)])
  @@index([tenantId, status])
  @@map("tenant_app_builds")
}

/// Artigos/textos longos que alimentam o RAG do chatbot (corpus léxico + semântico).
/// Materiais de estudo, regimentos, normas, eventos, horários, guias etc.
/// Sem PII; base legal: LGPD art. 7º II e III. Por tenant com RLS — migration 072.
/// NOTA: a coluna `busca` (tsvector GENERATED ALWAYS) não é mapeada porque o
/// Prisma Client não suporta colunas geradas read-only. FTS usa $queryRaw.
model IaConteudo {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String      @map("tenant_id") @db.Uuid
  secretariaId   String?     @map("secretaria_id") @db.Uuid
  categoria      String?
  titulo         String
  conteudo       String
  tags           String[]
  publico        Boolean     @default(true)
  ativo          Boolean     @default(true)
  vigenciaInicio DateTime?   @map("vigencia_inicio") @db.Date
  vigenciaFim    DateTime?   @map("vigencia_fim") @db.Date
  criadoEm       DateTime    @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm   DateTime    @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  // busca tsvector GENERATED ALWAYS — usar $queryRaw para FTS (igual a ia_conhecimento)
  secretaria     Secretaria? @relation(fields: [secretariaId], references: [id], onDelete: SetNull)
  @@index([tenantId, secretariaId])
  @@index([tenantId, ativo])
  @@map("ia_conteudos")
}

// ---- Campanhas (migration 084) ----

/// Biblioteca GLOBAL de presets de campanha da plataforma Lidera.
/// Sem tenant_id — leitura livre; escrita restrita ao super_admin (app_is_platform()).
/// Presets são instalados pelos tenants via POST /api/admin/campanhas/instalar.
/// Sem PII; base legal: LGPD art. 7º III e IX (comunicação institucional).
model CampaignTemplate {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key                 String    @unique
  nome                String
  categoria           String
  descricao           String?
  icone               String?
  configDefault       Json      @default("{}") @map("config_default")
  sugestao            Json      @default("{}")
  prioridadeSugerida  Int       @default(100) @map("prioridade_sugerida")
  ativo               Boolean   @default(true)
  criadoEm            DateTime  @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm        DateTime  @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  @@index([categoria, ativo])
  @@map("campaign_template")
}

/// Instância de campanha institucional por tenant.
/// O resolver GET /api/campanhas/ativas filtra por janela de datas + status
/// e resolve conflitos de capacidades por prioridade.
/// Sem PII; base legal: LGPD art. 7º III e IX. Por tenant com RLS — migration 084.
model Campaign {
  id           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String                  @map("tenant_id") @db.Uuid
  templateKey  String?                 @map("template_key")
  nome         String
  status       String                  @default("draft")
  startsAt     DateTime?               @map("starts_at") @db.Timestamptz(6)
  endsAt       DateTime?               @map("ends_at") @db.Timestamptz(6)
  recorrencia  Json?
  autonomous   Boolean                 @default(false)
  prioridade   Int                     @default(100)
  config       Json                    @default("{}")
  criadoPor    String?                 @map("criado_por") @db.Uuid
  criadoEm     DateTime                @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm DateTime                @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  criador      User?                   @relation(fields: [criadoPor], references: [id], onDelete: SetNull)
  logs         CampaignActivationLog[]
  @@index([tenantId, status])
  @@index([tenantId, startsAt, endsAt])
  @@index([tenantId])
  @@map("campaign")
}

/// Auditoria de ativações e transições de campanhas por tenant.
/// Complementa audit_log (regra inviolável 6) com granularidade específica
/// do módulo. Append-only — sem UPDATE. Sem PII — migration 084.
model CampaignActivationLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  campaignId  String   @map("campaign_id") @db.Uuid
  acao        String
  ator        String
  detalhes    Json     @default("{}")
  criadoEm    DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  @@index([tenantId, campaignId])
  @@map("campaign_activation_log")
}
