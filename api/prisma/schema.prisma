  botTentativas          Int       @default(0) @map("bot_tentativas")
  manifestacaoId         String?   @map("manifestacao_id") @db.Uuid
  manifestacaoProtocolo  String?   @map("manifestacao_protocolo")
  /// FK para tenant_whatsapp_canais — canal Meta que originou a conversa (migration 081).
  /// Quando preenchido, respostas de saída são roteadas pelo mesmo número.
  canalId                String?   @map("canal_id") @db.Uuid
  cidadao                User?     @relation("AtendConversaCidadao", fields: [cidadaoId], references: [id], onDelete: SetNull)
  agente                 User?     @relation("AtendConversaAgente", fields: [agenteId], references: [id], onDelete: SetNull)
  canal_whatsapp         TenantWhatsappCanal? @relation(fields: [canalId], references: [id], onDelete: SetNull)
  mensagens              AtendimentoMensagem[]
  eventos                AtendimentoEvento[]
  @@index([tenantId, status])
  @@index([tenantId, secretariaId])
  @@map("atendimento_conversas")
}

